# Copy to .env for local development (vercel dev loads these automatically when linked)

# Required — Anthropic chat for all accelerators
ANTHROPIC_API_KEY=sk-ant-...

# Required — Neon Postgres (projects, saved outputs, RAG knowledge store)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Optional — override default Sonnet model
ANTHROPIC_MODEL=claude-sonnet-4-6

# Recommended — Voyage AI embeddings for project knowledge (RAG)
# Sign up at https://www.voyageai.com — used to embed and search client standards, uploads, saved outputs
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-3-lite

# Optional — alternative embedding provider (used only if VOYAGE_API_KEY is unset)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Auto-index saved accelerator outputs into project knowledge (default: true)
RAG_AUTO_INDEX_ARTIFACTS=true
